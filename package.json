{
  "name": "snowball",
  "version": "0.3.1",
  "description": "Snowball word stemming algorithm implementation",
  "keywords": [
    "nlp",
    "word stemming",
    "snowball",
    "stemmer"
  ],
  "author": "Oleg Mazko",
  "license": "MPL-1.1",
  "main": "./stemmer/lib/Snowball.js",
  "files": [
    "stemmer/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mlengse/snowball-js.git"
  },
  "bugs": {
    "url": "https://github.com/mlengse/snowball-js/issues"
  },
  "homepage": "https://github.com/mlengse/snowball-js#readme",
  "engines": {
    "node": ">=0"
  },
  "scripts": {
    "build": "node build.js && npm run minify",
    "minify": "terser stemmer/lib/Snowball.js -o stemmer/lib/Snowball.min.js -c -m --comments '/^!/'",
    "lint": "eslint stemmer/src/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "snowball-stemmers": "^0.6.0",
    "terser": "^5.49.0",
    "vitest": "^4.1.10"
  }
}
